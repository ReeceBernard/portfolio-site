# Copy this to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# Required for analyze-property
ANTHROPIC_API_KEY=sk-ant-...

# Required for analyze-property and hud-proxy
HUD_API_KEY=...

# Required for fred-proxy
FRED_API_KEY=...

# Required for calls-remaining and analyze-property rate limiting
# Can omit locally — rate limiting is skipped when REDIS_URL is absent
REDIS_URL=redis://...

# Required for comps (S3 + DuckDB)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
DEALSCOUT_S3_BUCKET=dealscout-data-dev

# Tells the Lambda handlers to allow http://localhost:5173 in CORS
IS_DEV=true
